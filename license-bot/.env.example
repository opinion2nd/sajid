DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash-command registration to one server for faster iteration.
DISCORD_GUILD_ID=

# Base URL of the license-server (anti-freecam/license-server) this bot manages.
LICENSE_SERVER_URL=http://localhost:3000
# Must match the license-server's ADMIN_SECRET env var.
LICENSE_ADMIN_SECRET=

# Comma-separated Discord user/role IDs allowed to run /license commands.
LICENSE_BOT_ADMIN_USER_IDS=
LICENSE_BOT_ADMIN_ROLE_IDS=
