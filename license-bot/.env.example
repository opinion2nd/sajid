DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register commands to a single server instantly while testing.
DISCORD_GUILD_ID=

# Port the verification REST API listens on (used by your sold software).
# Most free hosting platforms set PORT automatically — that takes priority over this.
LICENSE_API_PORT=3000

# Optional: override the license key charset (default = no 0/O/1/I mix-ups).
LICENSE_KEY_CHARSET=ABCDEFGHJKLMNPQRSTUVWXYZ23456789
