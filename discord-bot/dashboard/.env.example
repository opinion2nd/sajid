DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
# Must match a redirect URI registered in the Discord Developer Portal
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Random 32+ char secret used to sign session cookies
SESSION_SECRET=
# Path to the bot's SQLite database (shared with the bot process)
BOT_DB_PATH=../data/bot.sqlite3
