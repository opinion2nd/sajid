DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash-command registration to one server for faster iteration.
DISCORD_GUILD_ID=

# License system (optional)
# Port the REST verification API listens on. Used by your own software to call /api/auth/verify.
LICENSE_API_PORT=3000
# Characters used when generating license keys. Defaults to an unambiguous 32-char set (no 0/O/1/I).
LICENSE_KEY_CHARSET=ABCDEFGHJKLMNPQRSTUVWXYZ23456789
# Optional Discord webhook URL for license/product create/delete audit logs.
LICENSE_WEBHOOK_URL=
