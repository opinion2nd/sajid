{
  "name": "brother-craft-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "obfuscate": "rm -rf dist-obf && javascript-obfuscator dist -o dist-obf --config obfuscator.config.json",
    "build:sell": "npm run build && npm run obfuscate && node scripts/make-sell-package.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "javascript-obfuscator": "^5.4.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "better-sqlite3": true,
    "esbuild": true,
    "@napi-rs/canvas": true
  }
}
