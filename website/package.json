{
  "name": "brother-craft",
  "version": "0.1.0",
  "private": true,
  "description": "Brother Craft — Minecraft multi-vendor marketplace (web, Discord bot, license API)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @brothercraft/db generate",
    "db:migrate": "pnpm --filter @brothercraft/db migrate",
    "db:studio": "pnpm --filter @brothercraft/db studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
