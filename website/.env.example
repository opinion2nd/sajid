# ── App ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Database (Postgres) ───────────────────────────────
DATABASE_URL=postgresql://brothercraft:brothercraft@localhost:5432/brothercraft?schema=public

# ── Redis (cache + BullMQ queue) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth.js (NextAuth v5) ─────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ── Internal service-to-service auth ──────────────────
# Admin endpoints (license generate/revoke/unbind) + bot->API token
ADMIN_SECRET=replace-me-admin-secret
SERVICE_TOKEN=replace-me-service-token

# ── Payments: SSLCommerz (bKash / Nagad / cards) ──────
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true

# ── Object storage (S3-compatible, e.g. Cloudflare R2) ─
STORAGE_ENDPOINT=
STORAGE_BUCKET=brothercraft-files
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ── Transactional email (Resend / Postmark) ───────────
EMAIL_API_KEY=
EMAIL_FROM=no-reply@brothercraft.example

# ── Discord bot ───────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CUSTOMER_ROLE_ID=

# ── Storage driver (local for dev, s3 for prod R2/S3) ──
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
